{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-4a5b-8c9d-0e1f2a3b4c5d",
    "name": "Safe-Vote Strategy Stack",
    "description": "End-to-end strategy for the Safe-Vote Gateway. Mirrors the Python E2E test logic including baseline checks and cleanup.",
    "schema": "https://www.google.com/search?q=https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "E2E: Successful Vote with Increment Check",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// 1. SETUP: Get a temporary image and check baseline\r",
              "const apiKey = pm.environment.get("
              CAT_API_KEY
              ");\r",
              "const subId = "
              postman-e2e-user
              ";\r",
              "pm.collectionVariables.set("
              subId
              ", subId);\r",
              "\r",
              "// Get an image ID to vote on\r",
              "pm.sendRequest({\r",
              "    url: 'https://www.google.com/search?q=https://api.thecatapi.com/v1/images/search',\r",
              "    method: 'GET',\r",
              "    header: { 'x-api-key': apiKey }\r",
              "}, (err, res) => {\r",
              "    const imageId = res.json()[0].id;\r",
              "    pm.collectionVariables.set("
              tempImageId
              ", imageId);\r",
              "    \r",
              "    // Get baseline count\r",
              "    pm.sendRequest({\r",
              "        url: https://api.thecatapi.com/v1/votes?sub_id=${subId},\r",
              "        method: 'GET',\r",
              "        header: { 'x-api-key': apiKey }\r",
              "    }, (err, res) => {\r",
              "        pm.collectionVariables.set("
              initialCount
              ", res.json().length);\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "const apiKey = pm.environment.get("
              CAT_API_KEY
              ");\r",
              "const subId = pm.collectionVariables.get("
              subId
              ");\r",
              "\r",
              "pm.test("
              Status
              code
              is
              201
              ", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test("
              Message
              is
              SUCCESS
              ", function () {\r",
              "    pm.expect(jsonData.message).to.eql("
              SUCCESS
              ");\r",
              "});\r",
              "\r",
              "const voteId = jsonData.id;\r",
              "\r",
              "// 2. VERIFY: Check if count incremented in the Cat API\r",
              "pm.sendRequest({\r",
              "    url: https://api.thecatapi.com/v1/votes?sub_id=${subId},\r",
              "    method: 'GET',\r",
              "    header: { 'x-api-key': apiKey }\r",
              "}, (err, res) => {\r",
              "    pm.test("
              Vote
              count
              incremented
              by
              1
              ", function () {\r",
              "        const initialCount = pm.collectionVariables.get("
              initialCount
              ");\r",
              "        pm.expect(res.json().length).to.eql(initialCount + 1);\r",
              "    });\r",
              "\r",
              "    // 3. CLEANUP: Delete the vote\r",
              "    pm.sendRequest({\r",
              "        url: https://api.thecatapi.com/v1/votes/${voteId},\r",
              "        method: 'DELETE',\r",
              "        header: { 'x-api-key': apiKey }\r",
              "    }, (err, res) => {\r",
              "        console.log("
              Cleanup
              :
              Vote
              deleted
              ", voteId);\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    "
          image_id
          ": "
    {
    {
      tempImageId
    }
  }
    ",\n    "
    sub_id
    ": "
    {
    {
      subId
    }
  }
    ",\n    "
    value
    ": 8\n}",
    "options"
    :
    {
      "raw": {
        "language": "json"
      }
    }
    },
    "url"
    :
    {
      "raw": "{{base_url}}/safe-vote",
      "host": [
        "{{base_url}}"
      ],
      "path": [
        "safe-vote"
      ]
    }
    },
    "response"
    :
    []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "tempImageId",
      "value": ""
    },
    {
      "key": "subId",
      "value": ""
    },
    {
      "key": "initialCount",
      "value": ""
    }
  ]
}